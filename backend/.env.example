SECRET_KEY=change-me
FRONTEND_ORIGIN=http://localhost:5173
# Must match the redirect URL registered in the Tink Console for this client.
TINK_REDIRECT_URI=http://localhost:5173/auth/tink-callback
TINK_CLIENT_ID=
TINK_CLIENT_SECRET=
DATABASE_PATH=valut.db
PORT=5173

# Montrose MCP: client_id comes from POST {issuer}/register on each connect; tokens stored per user in DB.
# Redirect URI must match the SPA route and what you pass to /register (default uses FRONTEND_ORIGIN).
# MONTROSE_REDIRECT_URI=http://localhost:5173/auth/montrose-callback
# MONTROSE_CLIENT_NAME=Valut
# MONTROSE_MCP_BASE_URL=https://mcp.montrose.io
# MONTROSE_ISSUER=https://mcp.montrose.io
# MONTROSE_SCOPE=mcp
# MONTROSE_MCP_TIMEOUT=30
