SECRET_KEY=change-me
FRONTEND_ORIGIN=http://localhost:5173
# Must match the redirect URL registered in the Tink Console for this client.
TINK_REDIRECT_URI=http://localhost:5173/auth/tink-callback
TINK_CLIENT_ID=
TINK_CLIENT_SECRET=
DATABASE_PATH=valut.db
PORT=5173

# Krävs för /api/agent/assess (Claude portföljagent). Utan nyckel returneras 503 med tydligt felmeddelande.
# ANTHROPIC_API_KEY=

# Fund-parser (fondfakta / verktyg i agenten). Standard om utelämnad:
# FUND_PARSER_URL=http://localhost:8000

# Optional mock/real holdings microservice (Tink-shaped JSON). When set, account balances for snapshots
# come from GET {URL}/v1/accounts instead of Tink fetch_accounts (Tink OAuth still used for login when configured).
# HOLDINGS_SERVICE_URL=http://127.0.0.1:5280
# HOLDINGS_SERVICE_TIMEOUT=15

# Montrose MCP: client_id comes from POST {issuer}/register on each connect; tokens stored per user in DB.
# Redirect URI must match the SPA route and what you pass to /register (default uses FRONTEND_ORIGIN).
# MONTROSE_REDIRECT_URI=http://localhost:5173/auth/montrose-callback
# MONTROSE_CLIENT_NAME=Valut
# MONTROSE_MCP_BASE_URL=https://mcp.montrose.io
# MONTROSE_ISSUER=https://mcp.montrose.io
# MONTROSE_SCOPE=mcp
# MONTROSE_MCP_TIMEOUT=30
